# DEMA Configuration — central source of truth for all services
# System
DEMA_ENV=prod
DEMA_HOST=localhost
DEMA_PORT=8090
DEMA_LOG_LEVEL=info

# LLM Configuration
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL_NAME=hermes-3-llama-3.1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Gateway Configuration
GATEWAY_URL=http://localhost:8080
GATEWAY_SECRET=
GATEWAY_SKILLS_SERVER=skills-provider

# Memory Configuration
MEMORY_P2_THRESHOLD=2000
MEMORY_P3_TTL=3600
